// Prisma 데이터베이스 스키마 - 기업, 제품, 배출 활동 데이터, 배출 계수 및 이력 관리를 위한 데이터 모델을 정의합니다.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String        @id
  name      String
  country   String
  emissions GhgEmission[]
  posts     Post[]
  products  Product[]
}

model Product {
  id        String        @id @default(cuid())
  name      String
  sku       String?
  category  String?
  unit      String?
  companyId String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  emissions GhgEmission[]
  company   Company       @relation(fields: [companyId], references: [id])
}

model GhgEmission {
  id               Int             @id @default(autoincrement())
  yearMonth        String
  source           String?
  emissions        Float
  companyId        String
  activityValue    Float?
  category         String?
  emissionFactorId String?
  unit             String?
  lifecycleStage   LifecycleStage?
  productId        String?
  scope            GhgScope?
  company          Company         @relation(fields: [companyId], references: [id])
  emissionFactor   EmissionFactor? @relation(fields: [emissionFactorId], references: [id])
  product          Product?        @relation(fields: [productId], references: [id])
}

model Post {
  id          String  @id
  title       String
  resourceUid String
  dateTime    String
  content     String
  company     Company @relation(fields: [resourceUid], references: [id])
}

model EmissionFactor {
  id           String                  @id @default(cuid())
  category     String
  name         String
  unit         String
  currentValue Float
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  versions     EmissionFactorVersion[]
  ghgEmissions GhgEmission[]
}

model EmissionFactorVersion {
  id            String         @id @default(cuid())
  factorId      String
  value         Float
  versionNumber Int
  validFrom     DateTime       @default(now())
  remarks       String?
  createdAt     DateTime       @default(now())
  factor        EmissionFactor @relation(fields: [factorId], references: [id])
}

enum LifecycleStage {
  RAW_MATERIAL
  PRODUCTION
  TRANSPORTATION
  USE
  DISPOSAL
}

enum GhgScope {
  SCOPE_1
  SCOPE_2
  SCOPE_3
}
